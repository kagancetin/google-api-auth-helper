{
  "compilerOptions": {
    /* Temel Ayarlar */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",  
    "declaration": true,          
    "sourceMap": true,
    "esModuleInterop": true,      
    "forceConsistentCasingInFileNames": true,
    "strict": true,                
    "skipLibCheck": true ,
    "outDir": "./dist",  
    "rootDir": "./src",  
    "isolatedModules": true  
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}